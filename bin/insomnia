#!/usr/bin/env bash

####################################
# insomnia
# written by Jeff Wang
# created 2026.03.05
####################################

usage ()
{
	echo "$(basename "$0") [on|off]"
	exit ${1:-1}
}

args=()
opts=()

while [[ $# -gt 0 ]]; do
	case "$1" in
		-h|--help)
			usage 0
			;;
		-*)
			opts+=("$1")
			shift
			;;
		*)
			args+=("$1")
			shift
			;;
	esac
done

# [[ "${#opts[@]}" -ne 0 ]] && usage
[[ "${#args[@]}" -gt 1 ]] && usage
[[ "${#opts[@]}" -ne 0 ]] && usage

cmd="${args[0]}"

on() {
	echo "=== $cmd ==="
	set -x
	killall caffeinate 2>/dev/null
	nohup caffeinate -dimsu >/dev/null 2>&1 &
	sudo pmset -c disablesleep 1 sleep 0 displaysleep 0 disksleep 0
}

off() {
	echo "=== $cmd ==="
	set -x
	killall caffeinate
	sudo pmset -c restoredefaults
}

case "$cmd" in
	on|off)
		$cmd
		;;
	"")
		ps | grep [c]affeinate && off || on
		;;
	*)
		usage
		;;
esac


